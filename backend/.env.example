# ============================================================================
# Template for environment variables
# Copy to .env and fill in your values
# ============================================================================

ENVIRONMENT=development
DEBUG=True

BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

DATA_DIR=./backend/data
MODELS_DIR=./backend/models
LOG_DIR=./logs

CLINVAR_CSV_PATH=./backend/data/clinvar_database.csv
VECTOR_STORE_PATH=./backend/data/clinvar_indexed
EMBEDDING_MODEL=text-embedding-3-small
GEMINI_EMBEDDING_MODEL=models/embedding-001
GEMINI_GENERATION_MODEL=
LLM_MODEL=
USE_LLAMAINDEX=True
USE_GEMINI_EMBEDDINGS=True
GEMINI_API_KEY=
NCBI_EMAIL=your_email@example.com
NCBI_API_KEY=
CACHE_DIR=./backend/data/cache
SQLITE_CACHE_PATH=./backend/data/cache.db
CACHE_TTL_SECONDS=86400

VECTOR_DB_TYPE=faiss

LOG_LEVEL=INFO
LOG_FILE=./logs/application.log

ML_MODEL_PATH=./backend/models/random_forest_model.pkl
ML_SCALER_PATH=./backend/models/feature_scaler.pkl
USE_ML_CLASSIFIER=True

MAX_SEQUENCE_LENGTH=50000
REQUEST_TIMEOUT=300
