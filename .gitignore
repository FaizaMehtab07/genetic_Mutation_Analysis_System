# ============================================================================
# Root Level Gitignore
# ============================================================================

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/

# ============================================================================
# IDE
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# Environment
# ============================================================================
.env
.env.local
frontend/.env
frontend/.env.local
backend/data/variant_summary.txt

# ============================================================================
# Logs
# ============================================================================
logs/
*.log

# ============================================================================
# Test artifacts (development only)
# ============================================================================
temp_*.py
test_*.py
test_*.json

# ============================================================================
# OS
# ============================================================================
.DS_Store
Thumbs.db

# ============================================================================
# Dependencies
# ============================================================================
node_modules/
package-lock.json
